---
---

<section id="contact" class="py-24 bg-oatmilk overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16 animate-on-scroll">
      <span class="text-sage font-bold uppercase tracking-widest text-xs mb-4 block">Let's Connect</span>
      <h2 class="text-4xl md:text-5xl font-serif font-bold text-espresso mb-6">
        Wir freuen uns auf dich!
      </h2>
      <div class="w-24 h-1 bg-sage mx-auto"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <!-- Contact & Reservation Details -->
      <div class="space-y-12 animate-on-scroll">
        <!-- Reservation Widget Placeholder -->
        <div class="bg-white p-8 shadow-2xl border-t-8 border-sage">
          <h3 class="text-2xl font-serif font-bold text-espresso mb-6">Tisch reservieren</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
            <input type="date" class="bg-cream border-none p-4 font-sans text-sm focus:ring-2 focus:ring-sage" />
            <input type="time" class="bg-cream border-none p-4 font-sans text-sm focus:ring-2 focus:ring-sage" />
            <select class="bg-cream border-none p-4 font-sans text-sm focus:ring-2 focus:ring-sage">
              <option>1 Person</option>
              <option selected>2 Personen</option>
              <option>4 Personen</option>
              <option>6 Personen</option>
              <option>Größere Gruppe</option>
            </select>
            <button class="bg-espresso text-oatmilk font-bold uppercase tracking-widest p-4 hover:bg-sage transition-colors duration-300">
              Verfügbarkeit prüfen
            </button>
          </div>
          <p class="text-xs text-espresso/40 italic text-center italic">Integration mit resmio / OpenTable möglich.</p>
        </div>

        <!-- Contact Box -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="space-y-4">
            <h4 class="text-lg font-bold uppercase tracking-widest text-espresso border-b border-espresso/10 pb-2">Standort</h4>
            <p class="text-espresso/70 font-sans leading-relaxed">
              Kausal Cafe & Bar<br />
              Flurstraße 1<br />
              40235 Düsseldorf
            </p>
            <a href="tel:021192412598" class="block text-espresso font-bold hover:text-sage transition-colors">
              📞 0211 - 92 41 25 98
            </a>
            <a href="mailto:Eteraz2002@yahoo.de" class="block text-espresso/70 hover:text-sage underline underline-offset-4 decoration-sage">
              Eteraz2002@yahoo.de
            </a>
          </div>

          <div class="space-y-4">
            <h4 class="text-lg font-bold uppercase tracking-widest text-espresso border-b border-espresso/10 pb-2">Öffnungszeiten</h4>
            <ul class="text-espresso/70 font-sans">
              <li class="flex justify-between py-1"><span>Montag - Sonntag</span> <span class="font-bold">09:00 – 22:00</span></li>
              <li class="mt-4 italic text-sm text-sage">Täglich frisch für euch da!</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Google Maps Embed -->
      <div class="w-full h-[500px] shadow-2xl relative group animate-on-scroll">
        <!-- Overlay to prevent accidental scrolling -->
        <div class="absolute inset-0 bg-espresso/10 group-hover:bg-transparent transition-colors duration-500 pointer-events-none"></div>
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2499.0494444!2d6.812!3d51.233!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47b8ca0000000000%3A0x0!2sKausal%20Cafe%20%26%20Bar!5e0!3m2!1sde!2sde!4v1234567890" 
          width="100%" 
          height="100%" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
          class="filter grayscale hover:grayscale-0 transition-all duration-700"
        ></iframe>
      </div>
    </div>
  </div>
</section>
