---
const features = [
  {
    icon: "☕",
    title: "Artisan Roasts",
    desc: "Vom Espresso zum Pour-over. Wir zelebrieren die Bohne in ihrer edelsten Form.",
    size: "large"
  },
  {
    icon: "☀️",
    title: "Urban Terrace",
    desc: "Dein Logenplatz in Flingern.",
    size: "small"
  },
  {
    icon: "💻",
    title: "Studio-Vibes",
    desc: "Co-Working mit dem besten WLAN der Stadt.",
    size: "medium"
  },
  {
    icon: "🐾",
    title: "Dog Friendly",
    desc: "Pfotenabdruck erwünscht.",
    size: "small"
  }
];
---

<section id="vibes" class="py-24 bg-cream overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Editorial Heading Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 mb-16 items-end">
      <div class="max-w-xl" data-animate>
        <span class="text-gold font-serif italic text-2xl mb-6 block">Kausal Philosophie.</span>
        <h2 class="text-6xl md:text-9xl font-serif font-bold text-espresso leading-[0.8] tracking-tighter">
          Echt. Analog. <br />
          <span class="italic text-gold">Flingern Soul.</span>
        </h2>
      </div>
      
      <div class="space-y-8" data-animate>
        <p class="text-2xl md:text-3xl text-espresso font-serif italic leading-relaxed">
          "Wir glauben an Momente, die man nicht streamen kann. Wir glauben an den warmen Klang einer Nadel auf Vinyl und den Duft von frisch gebrühtem Handfilter."
        </p>
        <div class="h-px w-full bg-gold/30"></div>
        <p class="text-espresso/60 font-sans leading-relaxed max-w-md">
          Das Kausal ist mehr als eine Adresse in Flingern – es ist ein kuratierter Raum für alle, die das Handwerk schätzen. Vom ersten Röstgrad bis zur letzten Note unserer Live-Sessions.
        </p>
      </div>
    </div>

    <!-- The Mosaic Concept Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 lg:gap-32 items-start mb-16">
      <!-- 01: Coffee & Cakes -->
      <div class="relative group" data-animate>
        <div class="gallery-frame group-hover:-rotate-1 transition-transform duration-700">
           <img src="/images/127987488_5262483980435764_1461431410841685995_n.jpg" alt="Artisan Cakes" class="w-full transition-all duration-1000 h-[600px] object-cover" />
        </div>
        <div class="mt-10">
          <h3 class="text-4xl font-serif font-bold text-espresso mb-6 uppercase tracking-tighter">Handwerk & Süßes.</h3>
          <p class="text-espresso/70 text-lg leading-relaxed max-w-sm font-sans mb-8">
            Unsere Kuchen sind so ehrlich wie unser Kaffee. Hausgebacken, saisonal und fernab von industrieller Perfektion. Wir feiern das Unvollkommene.
          </p>
          <div class="museum-label">ART-NO. 201 // FLINGERN KÜCHE</div>
        </div>
      </div>

      <!-- 02: Vinyl & Sound (With Animated Visual) -->
      <div id="vinyl-section" class="relative group md:mt-48" data-animate>
        <div class="relative mb-16 aspect-square flex items-center justify-center bg-espresso/5 border border-espresso/10 p-12 overflow-hidden">
          <!-- Animated Vinyl Visual -->
          <div class="relative w-full aspect-square bg-[#0a0a0a] rounded-full shadow-2xl flex items-center justify-center animate-spin-slow overflow-hidden">
             <!-- Deep Grooves Texture -->
             <div class="absolute inset-0 opacity-40" style="background: repeating-radial-gradient(circle, #000 0px, #000 1px, #1a1a1a 1.5px, #000 2px);"></div>
             <!-- Surface Shine/Reflections -->
             <div class="absolute inset-0 opacity-20 bg-gradient-to-tr from-transparent via-white/30 to-transparent"></div>
             <div class="absolute inset-0 opacity-10 bg-gradient-to-bl from-transparent via-white/20 to-transparent"></div>
             
             <!-- Center Label (The "Sticker") -->
             <div class="w-[35%] aspect-square bg-gold rounded-full flex flex-col items-center justify-center relative shadow-inner p-4 z-10 border border-espresso/10">
                <!-- Circular Text / Brand -->
                <span class="text-[7px] font-bold text-espresso uppercase tracking-[0.2em] mb-3">Kausal.</span>
                <!-- Spindle Hole (The "Perfect" Hole) -->
                <div class="w-2 h-2 bg-[#050505] rounded-full shadow-[inset_0_1px_2px_rgba(255,255,255,0.2)]"></div>
                <!-- Technical Specs -->
                <span class="text-[5px] font-bold text-espresso/40 uppercase tracking-widest mt-3">33 1/3 RPM</span>
             </div>
          </div>
          <!-- Stylus Arm -->
          <div class="absolute top-10 right-10 w-24 h-48 border-r-4 border-t-4 border-espresso/20 rounded-tr-3xl transition-transform duration-1000 origin-top-right stylus-arm rotate-[20deg]"></div>
        </div>
        
        <!-- Audio Element -->
        <audio id="jazz-audio" src="/audio/tatamusic-jazz-jazz-music-485401.mp3" loop preload="auto"></audio>
        
        <div>
          <h3 class="text-4xl font-serif font-bold text-espresso mb-6 uppercase tracking-tighter">Analoge Wärme.</h3>
          <p class="text-espresso/70 text-lg leading-relaxed max-w-sm font-sans mb-8">
            Bei uns gibt es keine Playlists von der Stange. Unsere Schallplatten-Sammlung ist das Herzschlag des Cafés. Kuratiert, analog, unverfälscht.
          </p>
          <div class="museum-label">ART-NO. 202 // ANALOG SESSIONS</div>
        </div>
      </div>
    </div>

    <!-- 03: The Terrace/Flingern Vibe (Wide Layout) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center" data-animate>
       <div class="lg:col-span-8 order-2 lg:order-1">
          <div class="gallery-frame h-[500px]">
             <img src="/images/private_event.jpg" alt="Flingern Vibe" class="w-full h-full object-cover" />
          </div>
       </div>
       <div class="lg:col-span-4 order-1 lg:order-2 space-y-8 px-6">
          <span class="text-gold font-mono uppercase tracking-[0.4em] text-xs">// Location</span>
          <h3 class="text-5xl font-serif font-bold text-espresso leading-none">Terrassen-Leben am Puls von Flingern.</h3>
          <p class="text-espresso/60 font-sans leading-relaxed">
            Sitzplätze draußen, den Blick auf die Flurstraße – hier wird das Viertel lebendig. Das Kausal ist der Logenplatz für alle, die Düsseldorf Flingern so lieben wie wir.
          </p>
          <div class="pt-8">
             <a href="#contact" class="btn-luxury group">Kontakt Aufnehmen</a>
          </div>
       </div>
    </div>
  </div>
</section>

<style>
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-spin-slow {
    animation: spin-slow 10s linear infinite;
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));

  // Audio Interaction Logic
  const vinylSection = document.getElementById('vinyl-section');
  const jazzAudio = document.getElementById('jazz-audio') as HTMLAudioElement;
  const stylusArm = document.querySelector('.stylus-arm') as HTMLElement;

  let fadeInterval: number | null = null;

  const fadeVolume = (audio: HTMLAudioElement, targetVolume: number) => {
    if (fadeInterval !== null) {
      clearInterval(fadeInterval);
      fadeInterval = null;
    }
    const step = 0.04;
    fadeInterval = window.setInterval(() => {
      if (Math.abs(audio.volume - targetVolume) < step) {
        audio.volume = targetVolume;
        clearInterval(fadeInterval!);
        fadeInterval = null;
        if (targetVolume === 0) audio.pause();
      } else {
        audio.volume = targetVolume > audio.volume
          ? Math.min(audio.volume + step, 1)
          : Math.max(audio.volume - step, 0);
      }
    }, 50);
  };

  if (vinylSection && jazzAudio && stylusArm) {
    vinylSection.addEventListener('mouseenter', () => {
      jazzAudio.volume = 0;
      jazzAudio.play().catch(e => console.warn('[Audio] Jazz play error:', e));
      fadeVolume(jazzAudio, 0.4);
      stylusArm.style.transform = 'rotate(0deg)';
    });

    vinylSection.addEventListener('mouseleave', () => {
      fadeVolume(jazzAudio, 0);
      stylusArm.style.transform = 'rotate(20deg)';
    });
  }

  // Unlock audio on first user interaction
  const unlockAudio = () => {
    if (jazzAudio) {
      const result = jazzAudio.play();
      if (result !== undefined) {
        result.then(() => jazzAudio.pause()).catch(() => {});
      }
    }
  };

  document.addEventListener('click', unlockAudio, { once: true });
  document.addEventListener('keydown', unlockAudio, { once: true });
  document.addEventListener('touchstart', unlockAudio, { once: true });
</script>
