---
---

<section id="private" class="py-32 bg-cream overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 relative z-10 flex flex-col lg:flex-row-reverse items-center gap-24">
    
    <!-- Image with Artistic Gallery Framing -->
    <div class="w-full lg:w-5/12 relative group" data-animate>
       <div class="gallery-frame">
         <img 
           src="/images/private_vibe.png" 
           alt="Cultural Events at Kausal" 
           class="w-full h-[500px] object-cover grayscale-[30%] group-hover:grayscale-0 transition-all duration-1000"
         />
         <div class="museum-label">
           No. 05 // Cultural Gatherings // Est. 2024
         </div>
       </div>
       
       <!-- Minimalist Detail -->
       <div class="absolute -top-6 -left-6 w-12 h-12 border-t-2 border-l-2 border-gold/30"></div>
    </div>

    <!-- Content: Editorial Layout -->
    <div class="w-full lg:w-7/12" data-animate>
      <span class="text-gold font-serif italic text-2xl mb-6 block">Exclusively.</span>
      <h2 class="text-5xl md:text-8xl font-serif font-bold text-espresso mb-10 leading-[0.85] tracking-tighter">
        Dein Moment. <br />
        <span class="text-gold italic">Unsere Bühne.</span>
      </h2>
      <p class="text-xl md:text-2xl text-espresso/70 font-sans leading-relaxed mb-12 max-w-xl">
        Ob kuratierte Themenabende, Lesungen oder Vinyl-Sessions – wir verwandeln das Kausal in deine ganz persönliche Bühne für besondere Momente.
      </p>

      <div class="grid grid-cols-2 gap-12 mb-16 max-w-md">
        <div class="border-l border-gold/30 pl-6">
            <p class="font-mono text-[10px] uppercase tracking-widest text-gold mb-2">Space</p>
            <p class="text-espresso font-serif text-2xl italic">80 Gäste</p>
        </div>
        <div class="border-l border-gold/30 pl-6">
            <p class="font-mono text-[10px] uppercase tracking-widest text-gold mb-2">Service</p>
            <p class="text-espresso font-serif text-2xl italic">Full Curated</p>
        </div>
      </div>

      <a 
        href="#contact" 
        class="group relative inline-flex items-center gap-8 border border-espresso/20 px-8 py-5 transition-all duration-500 hover:border-espresso hover:bg-espresso hover:text-oatmilk overflow-hidden"
      >
        <span class="z-10 font-bold uppercase tracking-[0.3em] text-xs">Anfrage senden</span>
        <svg class="z-10 w-5 h-5 transform group-hover:translate-x-2 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
