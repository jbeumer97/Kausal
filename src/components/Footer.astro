---
const currentYear = new Date().getFullYear();
const seoTags = [
  "Café Düsseldorf", "Kaffeerösterei Flingern", "Frühstück Düsseldorf", 
  "Bar Flingern", "Hochzeitslocation Café", "Live Musik Bar Düsseldorf"
];
---

<footer class="bg-espresso pt-40 pb-20 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-16 mb-32 items-start">
      
      <!-- Brand & Mission: Dramatic Side -->
      <div class="lg:col-span-5 space-y-12">
        <a href="/" class="flex flex-col group">
          <span class="text-7xl font-serif font-bold text-oatmilk group-hover:text-gold transition-colors duration-700 leading-none">
            Kausal.
          </span>
          <span class="text-[12px] uppercase tracking-[0.6em] font-bold text-gold/40 mt-4 underline-gold">
            The Art of Flingern
          </span>
        </a>
        <p class="text-oatmilk/40 font-sans text-lg leading-relaxed max-w-sm italic">
          Ein eklektischer Rückzugsort für Kunstliebhaber, Kaffeekenner und Nachteulen. Specialty Coffee trifft auf urbane Bar-Kultur.
        </p>
      </div>

      <!-- Quick Links: Gallery Style -->
      <div class="lg:col-span-3 space-y-8">
        <h4 class="text-[10px] font-bold uppercase tracking-[0.4em] text-gold/40 border-b border-gold/10 pb-4">Explore</h4>
        <ul class="space-y-4 text-oatmilk/70 font-serif italic text-xl">
          <li><a href="#" class="hover:text-gold transition-colors">Menu (2024)</a></li>
          <li><a href="#" class="hover:text-gold transition-colors">Impressum</a></li>
          <li><a href="#" class="hover:text-gold transition-colors">Privacy</a></li>
          <li><a href="#" class="hover:text-gold transition-colors">Events</a></li>
        </ul>
      </div>

      <!-- Local Social: Impactful -->
      <div class="lg:col-span-4 space-y-8">
        <h4 class="text-[10px] font-bold uppercase tracking-[0.4em] text-gold/40 border-b border-gold/10 pb-4">Say Hello</h4>
        <div class="flex gap-8 items-center text-oatmilk group">
           <a href="#" class="hover:text-gold transition-all duration-500 flex flex-col">
              <span class="text-4xl font-serif italic mb-2 tracking-tighter">Instagram.</span>
              <span class="text-[10px] uppercase font-bold tracking-widest text-gold/30">@kausal_flingern</span>
           </a>
        </div>
        <div class="flex gap-8 items-center text-oatmilk group mt-12">
           <a href="#" class="hover:text-gold transition-all duration-500 flex flex-col">
              <span class="text-4xl font-serif italic mb-2 tracking-tighter">Facebook.</span>
              <span class="text-[10px] uppercase font-bold tracking-widest text-gold/30">/kausalcafe</span>
           </a>
        </div>
      </div>
    </div>

    <!-- SEO & Baseline -->
    <div class="flex flex-col md:flex-row justify-between items-end gap-12 border-t border-gold/10 pt-16">
      <div class="flex flex-wrap gap-4 text-[9px] uppercase font-bold tracking-[0.4em]">
          {seoTags.map(tag => (
            <span class="text- gold/20 hover:text-gold transition-colors cursor-default">
              #{tag}
            </span>
          ))}
      </div>
      <div class="text-right">
        <p class="text-oatmilk/20 font-sans text-[10px] uppercase tracking-[0.4em] mb-2 shadow-sm">
          &copy; {currentYear} Kausal.
        </p>
        <p class="text- gold/10 font-serif italic text-sm">
          Made with passion in Düsseldorf Flingern.
        </p>
      </div>
    </div>
  </div>

  <!-- Distant Background Texture -->
  <div class="absolute inset-0 z-0 opacity-10 pointer-events-none stroke- gold">
     <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" class="w-full h-full opacity-5 rotate-180">
        <path d="M0,50 Q100,50 100,50" />
     </svg>
  </div>
</footer>
