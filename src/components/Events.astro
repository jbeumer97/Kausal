---
---

<section id="events" class="py-32 bg-espresso relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="flex flex-col lg:flex-row items-center gap-24">
      
      <!-- Video/Image side with Floating Elements -->
      <div class="w-full lg:w-1/2 relative group" data-animate>
        <div class="absolute -inset-8 bg-gold/10 border-2 border-gold/20 -translate-x-4 translate-y-4"></div>
        <img 
          src="/images/events.png" 
          alt="Live Musik Kausal" 
          class="relative w-full h-[600px] object-cover grayscale-[40%] group-hover:grayscale-0 transition-all duration-1000 shadow-3xl"
        />
        <!-- Floating Art Tag -->
        <div class="absolute top-[10%] -left-[10%] bg-gold text-espresso px-6 py-3 font-serif italic text-lg shadow-2xl rotate-[-3deg] hidden md:block">
          "Sound of the City"
        </div>
      </div>

      <!-- Content Side: Dramatic Typography -->
      <div class="w-full lg:w-1/2 text-oatmilk" data-animate>
        <span class="text-gold font-serif italic text-2xl mb-6 block drop-shadow-lg">After Dark.</span>
        <h2 class="text-5xl md:text-7xl font-serif font-bold mb-10 leading-[0.9] tracking-tighter">
          Flingern nach Feierabend: <br />
          <span class="text-gold italic underline-gold">Live Musik & Bar-Vibes.</span>
        </h2>
        
        <p class="text-xl md:text-2xl text-oatmilk/70 font-sans leading-relaxed mb-12 max-w-lg">
          Wenn die Sonne untergeht, verwandelt sich das Kausal in eine Bar. Schnapp dir einen Drink, lehn dich zurück und genieß den Sound der Stadt.
        </p>

        <div class="flex flex-wrap gap-8 items-center mt-12">
          <a 
            href="#contact" 
            class="group relative inline-flex items-center gap-6 border-b-2 border-gold pb-4 font-bold uppercase tracking-[0.2em] text-sm hover:text-gold transition-colors duration-500"
          >
            Zum Eventkalender
            <svg class="w-6 h-6 transform group-hover:translate-x-2 transition-transform duration-300 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <div class="flex flex-col border-l border-oatmilk/20 pl-6">
            <span class="text-gold uppercase tracking-widest text-xs font-bold mb-1">Coming Up</span>
            <span class="text-lg font-serif italic text-oatmilk">Jazz Night | Diesen Freitag ab 19:00</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Distant Doodle Accent -->
  <div class="absolute top-0 right-0 w-64 h-64 bg-gold/5 blur-[120px] rounded-full"></div>
</section>
