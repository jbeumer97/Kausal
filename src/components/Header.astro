---
const navLinks = [
  { name: "Home", href: "#home" },
  { name: "The Experience", href: "#vibes" },
  { name: "Events", href: "#events" },
  { name: "Celebrations", href: "#private" },
  { name: "Contact", href: "#contact" }
];
---

<header id="header" class="fixed top-0 left-0 w-full z-50 transition-all duration-700 bg-oatmilk/90 backdrop-blur-xl border-b border-gold/10">
  <nav class="max-w-7xl mx-auto px-6 py-6 flex items-center justify-between">
    <!-- Brand: Editorial Serif -->
    <a href="/" class="flex flex-col group">
      <span class="text-4xl font-serif font-bold text-espresso group-hover:text-gold transition-colors duration-500 leading-none">
        Kausal.
      </span>
      <span class="text-[10px] uppercase tracking-[0.4em] font-bold text-gold/60 mt-1">Düsseldorf Flingern</span>
    </a>

    <!-- Desktop Nav: Minimalist & Spaced -->
    <ul class="hidden lg:flex items-center gap-12 font-sans font-bold text-[10px] uppercase tracking-[0.3em] text-espresso/60">
      {navLinks.map(link => (
        <li>
          <a 
            href={link.href} 
            class="hover:text-gold transition-all duration-500 relative group"
          >
            {link.name}
            <span class="absolute -bottom-2 left-0 w-0 h-px bg-gold group-hover:w-full transition-all duration-500"></span>
          </a>
        </li>
      ))}
      <li>
        <a 
          href="#contact" 
          class="bg-espresso text-oatmilk px-8 py-4 font-bold uppercase tracking-[0.2em] text-[10px] hover:bg-gold transition-all duration-500 shadow-2xl"
        >
          Tisch reservieren
        </a>
      </li>
    </ul>

    <!-- Mobile Button -->
    <button id="mobile-menu-btn" class="lg:hidden text-espresso" aria-label="Menu">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 8h16M4 16h16"></path>
      </svg>
    </button>
  </nav>

  <!-- Gallery-Style Mobile Sidebar -->
  <div id="mobile-sidebar" class="fixed inset-0 bg-espresso/98 z-50 flex flex-col items-center justify-center translate-x-full transition-transform duration-700 lg:hidden">
    <button id="close-sidebar" class="absolute top-10 right-10 text-oatmilk" aria-label="Close">
      <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
    <ul class="flex flex-col items-center gap-10 text-3xl font-serif text-oatmilk italic">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="hover:text-gold transition-colors close-side-link">{link.name}</a>
        </li>
      ))}
      <li class="mt-8">
        <a href="#contact" class="bg-gold text-espresso px-10 py-5 font-bold rounded-none uppercase tracking-widest text-sm close-side-link shadow-3xl">
          Tisch reservieren
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const header = document.getElementById('header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      header?.classList.add('py-0', 'shadow-2xl');
    } else {
      header?.classList.remove('py-0', 'shadow-2xl');
    }
  });

  const menuBtn = document.getElementById('mobile-menu-btn');
  const sidebar = document.getElementById('mobile-sidebar');
  const closeBtn = document.getElementById('close-sidebar');
  
  menuBtn?.addEventListener('click', () => {
    sidebar.classList.remove('translate-x-full');
  });

  [closeBtn, ...sidebar.querySelectorAll('.close-side-link')].forEach(el => {
    el.addEventListener('click', () => {
      sidebar.classList.add('translate-x-full');
    });
  });
</script>
