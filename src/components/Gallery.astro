---
const images = [
  { src: "/images/127987488_5262483980435764_1461431410841685995_n.jpg", theme: "Taste", size: "large", speed: "1.1" },
  { src: "/images/486665660_1192047536261394_8751887505454784795_n.jpg", theme: "Sound", size: "medium", speed: "1.3" },
  { src: "/images/485727482_1189023223230492_8480639946500030034_n.jpg", theme: "Soul", size: "small", speed: "0.9" },
  { src: "/images/490302901_1209984121134402_5196203059986425627_n.jpg", theme: "Taste", size: "medium", speed: "1.2" },
  { src: "/images/30715702_2320539507963574_7028104266346659840_n.jpg", theme: "Soul", size: "large", speed: "0.8" },
  { src: "/images/489279089_29996503113273841_7392131242772176821_n.jpg", theme: "Sound", size: "medium", speed: "1.4" },
  { src: "/images/82032334_4457812320902938_3686642285681389064_n.jpg", theme: "Taste", size: "small", speed: "1.1" },
  { src: "/images/private_event.jpg", theme: "Soul", size: "large", speed: "1.0" },
];
---

<section id="gallery" class="py-48 bg-cream overflow-hidden">
  <div class="max-w-[1800px] mx-auto px-6 relative">
    
    <!-- Large Cinematic Heading Background -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 pointer-events-none select-none z-0">
      <h2 class="text-[15vw] font-serif font-bold text-espresso/[0.03] uppercase leading-none text-center">
        Curated<br />Moments
      </h2>
    </div>

    <!-- The Mosaic Grid -->
    <div class="relative grid grid-cols-1 md:grid-cols-12 gap-12 items-center min-h-[120vh]">
      {images.map((img, i) => (
        <div 
          class={`relative parallax-group group
            ${img.size === 'large' ? 'md:col-span-6' : ''}
            ${img.size === 'medium' ? 'md:col-span-4' : ''}
            ${img.size === 'small' ? 'md:col-span-3' : ''}
            ${i % 2 === 0 ? 'md:-translate-y-24' : 'md:translate-y-24'}
          `}
          data-speed={img.speed}
        >
          <div class="gallery-frame overflow-hidden relative border border-espresso/5 p-3 bg-white shadow-2xl transition-all duration-1000">
            <img 
              src={img.src} 
              alt={img.theme}
              class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-110 grayscale-[50%] group-hover:grayscale-0"
              loading="lazy"
            />
            
            <!-- Glass Label -->
            <div class="absolute bottom-6 left-6 glass-caption opacity-0 group-hover:opacity-100 transition-all duration-700 translate-y-10 group-hover:translate-y-0">
               <p class="font-mono text-[9px] tracking-[0.3em] text-white uppercase mb-1">Theme // {img.theme}</p>
               <p class="font-serif text-white italic text-lg opacity-80">Kausal Selection No. {i+1}</p>
            </div>
          </div>
          
          <!-- Technical Caption Tag -->
          <div class="museum-label flex justify-between items-center px-2">
            <span>{img.theme}</span>
            <span>0{i+1}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery-frame {
    aspect-ratio: 4/5;
  }
  
  .parallax-group {
    will-change: transform;
    transition: transform 0.1s linear;
  }

  @media (max-width: 768px) {
    .parallax-group {
      transform: none !important;
    }
  }
</style>

<script>
  // Advanced Parallax Scroll Logic
  const items = document.querySelectorAll('.parallax-group');
  
  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    items.forEach((item) => {
      const speed = parseFloat(item.getAttribute('data-speed') || '1');
      const rect = item.getBoundingClientRect();
      const offset = rect.top + scrollY - window.innerHeight / 2;
      const move = (scrollY - offset) * (speed - 1) * 0.15;
      
      if (window.innerWidth > 1024) {
        (item as HTMLElement).style.transform = `translateY(${move}px)`;
      }
    });
  }, { passive: true });
</script>
