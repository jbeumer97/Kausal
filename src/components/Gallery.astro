---
const images = [
  { src: "/images/127987488_5262483980435764_1461431410841685995_n.jpg", caption: "Sweet Mornings", rotate: "-2deg" },
  { src: "/images/486665660_1192047536261394_8751887505454784795_n.jpg", caption: "Vinyl Vibes", rotate: "3deg" },
  { src: "/images/485727482_1189023223230492_8480639946500030034_n.jpg", caption: "Interior Love", rotate: "-1deg" },
  { src: "/images/490302901_1209984121134402_5196203059986425627_n.jpg", caption: "Golden Hour", rotate: "2deg" },
  { src: "/images/30715702_2320539507963574_7028104266346659840_n.jpg", caption: "Artisan Soul", rotate: "-3deg" },
  { src: "/images/489279089_29996503113273841_7392131242772176821_n.jpg", caption: "Live Sessions", rotate: "1deg" },
  { src: "/images/82032334_4457812320902938_3686642285681389064_n.jpg", caption: "Cake Art", rotate: "-2deg" },
  { src: "/images/private_event.jpg", caption: "Flingern Nights", rotate: "4deg" },
];
---

<section id="gallery" class="py-32 bg-cream overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 relative">
    
    <div class="text-center mb-16" data-animate>
      <span class="text-gold font-serif italic text-2xl mb-4 block">Eingefangene Momente.</span>
      <h2 class="text-5xl md:text-7xl font-serif font-bold text-espresso tracking-tighter">
        Kausal <span class="italic text-gold">Polaroids.</span>
      </h2>
    </div>

    <!-- The Polaroid Wall -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 md:gap-12 relative min-h-[80vh] items-center">
      {images.map((img, i) => (
        <div 
          class="flex justify-center"
          data-animate
          style={`transition-delay: ${i * 100}ms`}
        >
          <div 
            class="polaroid group" 
            style={`transform: rotate(${img.rotate});`}
          >
            <div class="push-pin"></div>
            <img 
              src={img.src} 
              alt={img.caption}
              loading="lazy"
            />
            <span class="polaroid-caption">{img.caption}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Decorative Texture -->
    <div class="absolute -bottom-10 -right-10 w-64 h-64 opacity-5 pointer-events-none">
       <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" class="text-espresso">
          <path d="M0,0 L100,100 M100,0 L0,100" stroke-width="0.5" />
       </svg>
    </div>
  </div>
</section>

<style>
  #gallery {
    /* Use a cork-like subtle texture or just the cream */
    background-image: radial-gradient(circle at 1px 1px, rgba(26, 19, 16, 0.05) 1px, transparent 0);
    background-size: 40px 40px;
  }
</style>

<script>
  // Simple intersection observer for animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));
</script>
